# ============================================================
# Dhan-Claude Trader — copy to ".env" and fill in real values.
# NEVER commit the real .env (it is gitignored).
# ============================================================

# ---- Dhan broker (required to run) ----
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# ---- AI providers ----
# Leave a key blank to keep that provider OFF even if enabled in providers.json.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# Signal source: mock = free rule-based signals (no AI key needed),
#                ai   = call the enabled providers in providers.json
SIGNAL_SOURCE=mock

# ---- Risk limits (defaults; ask before changing) ----
MAX_DAILY_LOSS=10000        # rupees
MAX_RISK_PER_TRADE_PCT=1.0  # percent of account equity
MAX_OPEN_POSITIONS=2

# ---- Trade mode default (UI can override at runtime) ----
# PAPER = orders mocked end-to-end | LIVE = real Dhan orders
TRADE_MODE=PAPER

# ---- Signal cost control ----
SIGNAL_COOLDOWN_SECONDS=300  # min seconds between signals per instrument

# Paper-mode starting capital (used for 1% risk sizing in PAPER)
ACCOUNT_CAPITAL=100000
